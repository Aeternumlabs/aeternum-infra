# KEEPER — APP-SPECIFIC ENVIRONMENT VARIABLES
# Shared variables (CHAIN_ID, RPC_URL, CONTRACT_ADDRESS, DATABASE_URL)
# are inherited from the root .env via dotenv-cli in the dev script.
# In Railway, they are injected via the shared variable group.

# --- Signing wallet ---
# The keeper's funded Ethereum private key. Used to sign and submit
# triggerRecovery transactions. Never commit this value. Never add it to
# the root .env or any shared variable group — it must remain isolated
# to this service's environment only.
KEEPER_PRIVATE_KEY=0xYourPrivateKeyHere

# --- Optional overrides ---
# These default to values in packages/config/src/constants.ts.
# Only set them here if you need to override the defaults.

# How often the keeper scans for due vaults (milliseconds).
# Default: 60000 (60 seconds)
KEEPER_POLL_INTERVAL_MS=60000

# Max vaults pulled from the DB per scan cycle.
# Default: 1000
KEEPER_BATCH_SIZE=1000
