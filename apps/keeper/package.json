{
  "name": "@aeternum/keeper",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":   "dotenv -e ../../.env -e .env -- tsx src/index.ts",
    "start": "dotenv -e ../../.env -e .env -- node dist/index.js",
    "build": "tsc",
    "lint":  "tsc --noEmit",
    "clean": "rm -rf dist",
    "test":            "vitest run",
    "test:unit":       "vitest run --project unit test/unit",
    "test:integration":"vitest run test/integration",
    "test:watch":      "vitest",
    "test:coverage":   "vitest run --coverage"
  },
  "dependencies": {
    "@aeternum/blockchain": "workspace:*",
    "@aeternum/config":     "workspace:*",
    "@aeternum/db":         "workspace:*",
    "viem":                 "^2.51.3",
    "zod":                  "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "dotenv-cli":  "^11.0.0",
    "tsx":         "^4.0.0",
    "typescript":  "^6.0.3",
    "vitest": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9"
  }
}