# Infrastructure environment variables Shared across all apps and packages. 
# App-specific variables (keeper signing key, etc.) live in each app's own
# .env.example under apps/<app>/.env.example
# Copy to .env and fill in values.

# Network
CHAIN_ID=YourChainId       // 1 (mainnet) | 11155111 (Sepolia) | 31337 (Anvil)
RPC_URL=YourSepoliaRpcUrl

# Contract
CONTRACT_ADDRESS=0xYourContractAddressHere
CONTRACT_DEPLOY_BLOCK=BlockNumber

# Database
# Shared by the indexer (Ponder writes) and keeper (reads via packages/db)
DATABASE_URL=postgresql://user:password@host:5432/aeternum
